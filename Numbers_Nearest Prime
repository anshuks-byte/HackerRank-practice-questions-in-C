/*
You are given an integer N. Your task is to find the nearest prime number to N.

If N itself is prime, return N.
If there are two prime numbers at the same minimum distance from N, return the smaller one.
Input Format

A single integer N
Constraints

1 ≤ N ≤ 10^6
Output Format

Print the nearest prime number to N.
Sample Input 0

13
Sample Output 0

13
Sample Input 1

8
Sample Output 1

7
*/




#include <stdio.h>
#include <math.h>
void nearestPrime()
{
    int n,p1,p2;
    scanf("%d",&n);
    if(n==1)
    {
        printf("2");
        return;
    }
    for(int i=n; ; ++i)
    {
        int j;
        for(j=2;j<=(int)sqrt(i);++j)
        {
            if(i%j==0)
                break;
        }
         if(j==((int)sqrt(i)+1))
        {
            p2=i;
            break;
        }
    }
    if(n==p2)
    {
        printf("%d",p2);
        return;
    }
    for(int i=n; ; --i)
    {
        int j;
        for(j=2;j<=(int)sqrt(i);++j)
        {
            if(i%j==0)
                break;
        }
         if(j==((int)sqrt(i)+1))
        {
            p1=i;
            break;
        }
    }
    if(n-p1>p2-n)
      printf("%d",p2);
    else
      printf("%d",p1);  
    
}
int main() {

   nearestPrime();
    return 0;
}
